{
  "name": "parcel-jest-base",
  "version": "1.0.0",
  "description": "",
  "default": "index.html",
  "type": "module",
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "collectCoverage": true,
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "coverageDirectory": "coverage",
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "scripts": {
    "start": "parcel index.html",
    "build": "parcel build index.html Surtidores/*.html Usuario_Administrador_Surtidor/*.html Usuario_particular/*.html Verificar_datos_registro/*.html Verificar_datos/*.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test-once": "jest Verificar_campos.test.js",
    "test:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "cypress": "cypress open",
    "cypress-run": "cypress run",
    "lint": "eslint .",
    "postinstall": "git init && npx husky",
    "semantic-commits-on": "node semantic-commits.js enable",
    "semantic-commits-off": "node semantic-commits.js disabled"
  },
  "author": "Israel Antezana R.",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "babel-jest": "^29.7.0",
    "cross-spawn": "^7.0.3",
    "cypress": "^13.13.3",
    "eslint": "^9.10.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "parcel": "^2.12.0"
  },
  "dependencies": {
    "parcel-jest-base": "file:"
  }
}
